# Application
NODE_ENV=development
PORT=8080

# Database (PostgreSQL)
# Example: postgresql://postgres:postgres@localhost:5432/healthcare?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/healthcare?schema=public

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-please-change-this
JWT_EXPIRATION=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

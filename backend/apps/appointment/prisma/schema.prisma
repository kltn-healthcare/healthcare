generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingType {
  DOCTOR
  PACKAGE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Booking {
  id                 String        @id @default(uuid())
  bookingNumber      String        @unique @map("booking_number")
  userId             String        @map("user_id") // ID trỏ sang Identity DB
  doctorId           String?       @map("doctor_id") // ID trỏ sang Clinic DB
  clinicId           String        @map("clinic_id") // ID trỏ sang Clinic DB
  type               BookingType
  scheduledDate      DateTime      @map("scheduled_date") @db.Date
  timeSlot           String        @map("time_slot") @db.VarChar(5)
  patientName        String        @map("patient_name")
  patientPhone       String        @map("patient_phone")
  patientEmail       String        @map("patient_email")
  patientGender      Gender?       @map("patient_gender")
  patientDob         DateTime?     @map("patient_dob") @db.Date
  reason             String        @db.Text
  symptoms           String?       @db.Text
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(UNPAID) @map("payment_status")
  paymentId          String?       @map("payment_id")
  paymentAmount      Decimal?      @map("payment_amount") @db.Decimal(12, 2)
  paymentUrl         String?       @map("payment_url") @db.Text
  checkoutSessionId  String?       @map("checkout_session_id")
  paymentMethod      String?       @map("payment_method") @db.VarChar(50)
  paymentInfo        Json?         @map("payment_info")
  canceledBy         String?       @map("canceled_by") @db.VarChar(50)
  cancelReason       String?       @map("cancel_reason") @db.Text
  notes              String?       @db.Text
  clinicNotes        String?       @map("clinic_notes") @db.Text
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  reminderLogs       BookingReminderLog[]
  review             Review?

  @@map("bookings")
  @@index([userId])
  @@index([doctorId])
  @@index([clinicId])
  @@index([status])
  @@index([scheduledDate])
  @@index([bookingNumber])
  @@index([createdAt])
}

model BookingReminderLog {
  id           String   @id @default(uuid())
  bookingId    String   @map("booking_id")
  reminderType String   @map("reminder_type")
  sentAt       DateTime @default(now()) @map("sent_at") @db.Timestamptz
  status       String
  error        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_reminder_logs")
  @@index([bookingId])
  @@index([sentAt])
}

model Review {
  id           String    @id @default(uuid())
  userId       String    @map("user_id") // ID trỏ sang Identity DB
  doctorId     String?   @map("doctor_id") // ID trỏ sang Clinic DB
  clinicId     String?   @map("clinic_id") // ID trỏ sang Clinic DB
  bookingId    String?   @unique @map("booking_id")
  rating       Int
  comment      String?   @db.Text
  replyComment String?   @map("reply_comment") @db.Text
  replyAt      DateTime? @map("reply_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  booking      Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("reviews")
  @@index([userId])
  @@index([doctorId])
  @@index([clinicId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
  CLINIC_ADMIN
}


enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BookingType {
  DOCTOR_CONSULTATION
  HEALTH_PACKAGE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
}

enum ReminderChannel {
  EMAIL
  IN_WEB
  WEB_PUSH
}

enum ReminderType {
  BEFORE_APPOINTMENT
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String?  @db.VarChar(20)
  avatar        String?  @db.Text
  role          UserRole @default(PATIENT)
  passwordHash  String   @map("password_hash")
  isActive      Boolean  @default(true) @map("is_active")
  emailVerified Boolean  @default(false) @map("email_verified")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  doctorProfile Doctor?
  clinicAdminProfile ClinicAdmin?
  bookings      Booking[]
  reviews       Review[]
  deviceTokens  UserDeviceToken[]
  notifications Notification[]

  @@map("users")
  @@index([role])
  @@index([createdAt])
}

model UserDeviceToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique @db.Text
  platform   String   @default("WEB") @db.VarChar(20)
  userAgent  String?  @map("user_agent") @db.Text
  isActive   Boolean  @default(true) @map("is_active")
  lastSeenAt DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_device_tokens")
  @@index([userId, isActive])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String           @db.Text
  data      Json?
  readAt    DateTime?        @map("read_at") @db.Timestamptz
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Clinic {
  id           String   @id @default(uuid())
  name         String
  description  String?  @db.Text
  address      String   @db.Text
  phone        String?  @db.VarChar(20)
  email        String?  @db.VarChar(255)
  website      String?  @db.Text
  rating       Decimal  @default(0.0) @db.Decimal(2, 1)
  reviewCount  Int      @default(0) @map("review_count")
  image        String?  @db.Text
  isOpen       Boolean  @default(true) @map("is_open")
  openingHours String?  @map("opening_hours") @db.Text
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  doctors        Doctor[]
  clinicAdmins   ClinicAdmin[]
  bookings       Booking[]
  reviews        Review[]
  healthPackages HealthPackage[]
  specialties    ClinicSpecialty[]
  workingHours   ClinicWorkingHour[]
  specialtySchedules ClinicSpecialtySchedule[]

  @@map("clinics")
  @@index([isOpen, rating])
  @@index([createdAt])
}

model ClinicAdmin {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  clinicId  String   @map("clinic_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_admins")
  @@index([clinicId])
}

model ClinicWorkingHour {
  id        String   @id @default(uuid())
  clinicId  String   @map("clinic_id")
  dayOfWeek Int      @map("day_of_week") @db.SmallInt
  isOpen    Boolean  @default(true) @map("is_open")
  startTime String   @map("start_time") @db.VarChar(5)
  endTime   String   @map("end_time") @db.VarChar(5)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, dayOfWeek])
  @@map("clinic_working_hours")
  @@index([clinicId, isOpen])
}

model Specialty {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  doctors Doctor[]
  clinics ClinicSpecialty[]
  specialtySchedules ClinicSpecialtySchedule[]
  healthPackages HealthPackage[]
  bookings Booking[]

  @@map("specialties")
}

model ClinicSpecialty {
  clinicId    String   @map("clinic_id")
  specialtyId String   @map("specialty_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  schedules ClinicSpecialtySchedule[]

  @@id([clinicId, specialtyId])
  @@map("clinic_specialties")
  @@index([specialtyId])
}

model ClinicSpecialtySchedule {
  id                  String   @id @default(uuid())
  clinicId            String   @map("clinic_id")
  specialtyId         String   @map("specialty_id")
  dayOfWeek           Int      @map("day_of_week") @db.SmallInt
  isActive            Boolean  @default(true) @map("is_active")
  startTime           String   @map("start_time") @db.VarChar(5)
  endTime             String   @map("end_time") @db.VarChar(5)
  slotDurationMinutes Int      @default(30) @map("slot_duration_minutes")
  capacity            Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  clinic          Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  specialty       Specialty       @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  clinicSpecialty ClinicSpecialty @relation(fields: [clinicId, specialtyId], references: [clinicId, specialtyId], onDelete: Cascade)

  @@map("clinic_specialty_schedules")
  @@index([clinicId, specialtyId, dayOfWeek, isActive])
}

model Doctor {
  id          String  @id @default(uuid())
  userId      String? @unique @map("user_id")
  clinicId    String  @map("clinic_id")
  specialtyId String  @map("specialty_id")

  name           String
  qualifications Json?
  experience     Int     @default(0)
  avatar         String? @db.Text
  bio            String? @db.Text
  isAvailable    Boolean @default(true) @map("is_available")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Restrict)
  bookings  Booking[]
  reviews   Review[]

  @@map("doctors")
  @@index([clinicId, specialtyId])
}

model Booking {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  clinicId     String        @map("clinic_id")
  doctorId     String?       @map("doctor_id")
  specialtyId  String?       @map("specialty_id")
  bookingType  BookingType   @default(DOCTOR_CONSULTATION) @map("booking_type")

  patientName  String        @map("patient_name")
  patientEmail String        @map("patient_email")
  patientPhone String        @map("patient_phone")
  patientDob   DateTime?     @map("patient_dob") @db.Date
  patientGender Gender?      @map("patient_gender")
  notes        String?       @db.Text

  bookingDate  DateTime      @map("booking_date") @db.Date
  bookingTime  String        @map("booking_time") @db.VarChar(10)
  status       BookingStatus @default(PENDING)

  cancellationReason String?  @map("cancellation_reason") @db.Text
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor Doctor? @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  specialty Specialty? @relation(fields: [specialtyId], references: [id], onDelete: SetNull)

  packageId    String?       @map("package_id")
  healthPackage HealthPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  review Review?
  reminderLogs BookingReminderLog[]

  @@map("bookings")
  @@index([userId, createdAt])
  @@index([clinicId, bookingDate])
  @@index([clinicId, specialtyId, bookingDate])
  @@index([packageId, bookingDate])
  @@index([status])
  @@index([status, bookingDate])
}

model BookingReminderLog {
  id           String          @id @default(uuid())
  bookingId    String          @map("booking_id")
  channel      ReminderChannel
  reminderType ReminderType    @default(BEFORE_APPOINTMENT) @map("reminder_type")
  scheduledFor DateTime        @map("scheduled_for") @db.Timestamptz
  status       ReminderStatus  @default(PENDING)
  sentAt       DateTime?       @map("sent_at") @db.Timestamptz
  attemptCount Int             @default(0) @map("attempt_count")
  error        String?         @db.Text
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_reminder_logs")
  @@unique([bookingId, channel, reminderType])
  @@index([status, scheduledFor])
}

model Article {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  image       String?  @db.Text
  category    String   @default("Cẩm nang")
  readTime    String   @default("5 phút") @map("read_time")
  publishedAt DateTime @default(now()) @map("published_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("articles")
  @@index([publishedAt])
  @@index([category])
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  doctorId  String?  @map("doctor_id")
  clinicId  String?  @map("clinic_id")
  bookingId String?  @unique @map("booking_id")

  rating    Int      @db.SmallInt
  comment   String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor  Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  clinic  Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("reviews")
  @@index([doctorId, createdAt])
  @@index([clinicId, createdAt])
  @@index([userId])
}

model HealthPackage {
  id               String   @id @default(uuid())
  name             String
  shortDescription String?  @map("short_description") @db.Text
  description      String   @db.Text
  price            Decimal  @db.Decimal(12, 2)
  promotionalPrice Decimal? @map("promotional_price") @db.Decimal(12, 2)
  currency         String   @default("VND")
  category         String   @default("basic") // e.g., general, cancer_screening, women, men
  
  targetGender     String?  @map("target_gender") // ALL, MALE, FEMALE
  targetAgeRange   String?  @map("target_age_range") // e.g., "18-60", "All"
  preparationNotes String?  @map("preparation_notes") @db.Text
  
  isPopular        Boolean  @default(false) @map("is_popular")
  isActive         Boolean  @default(true) @map("is_active")
  features         String[] // List of included tests/services
  imageUrl         String?  @map("image_url") @db.Text

  clinicId         String?  @map("clinic_id")
  clinic           Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  specialtyId      String?  @map("specialty_id")
  specialty        Specialty? @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  
  bookings         Booking[]
  availabilities   PackageAvailability[]

  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("health_packages")
  @@index([category, isActive])
  @@index([clinicId, isActive])
  @@index([specialtyId, isActive])
}

model PackageAvailability {
  id                  String   @id @default(uuid())
  packageId           String   @map("package_id")
  dayOfWeek           Int      @map("day_of_week") @db.SmallInt
  isActive            Boolean  @default(true) @map("is_active")
  startTime           String   @map("start_time") @db.VarChar(5)
  endTime             String   @map("end_time") @db.VarChar(5)
  slotDurationMinutes Int      @default(30) @map("slot_duration_minutes")
  capacity            Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  healthPackage HealthPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, dayOfWeek])
  @@map("package_availabilities")
  @@index([packageId, isActive])
}


pipeline {
    agent any

    environment {
        // ─── Registry ────────────────────────────────────────────────────────────
        GITEA_REGISTRY  = "gitea.kltn.internal:80"
        GITEA_OWNER     = "kltn"
        IMAGE_NAME      = "healthcare-frontend"
        GITEA_CREDS_ID  = "gitea-token-admin"

        // ─── SonarQube ───────────────────────────────────────────────────────────
        SONAR_SERVER    = "sonar-server"
        SONAR_SCANNER   = "sonar-scanner"

        // ─── Derived image tag (build number) ────────────────────────────────────
        IMAGE_TAG       = "${GITEA_REGISTRY}/${GITEA_OWNER}/${IMAGE_NAME}:${BUILD_NUMBER}"
    }

    options {
        timestamps()                        // Prepend timestamps to every log line
        disableConcurrentBuilds()           // Prevent race conditions on shared runners
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        // ── 0. System snapshot (useful for debugging runner capacity) ─────────────
        stage('System Information') {
            steps {
                sh '''
                    echo "=== CPU ===" && lscpu | grep -E "Model|Socket|Core|Thread" || true
                    echo "=== RAM ===" && free -mh
                    echo "=== Disk ===" && df -h
                    echo "=== Docker ===" && docker version --format "Client: {{.Client.Version}}  Server: {{.Server.Version}}"
                '''
            }
        }

        // ── 1. Checkout ───────────────────────────────────────────────────────────
        stage('Step 1: Checkout') {
            steps {
                checkout scm
                echo "Branch: ${env.BRANCH_NAME ?: 'N/A'} | Commit: ${env.GIT_COMMIT?.take(8) ?: 'N/A'}"
            }
        }

        // ==========================================
        // PHẦN A: LUỒNG CI & STAGING (Chỉ chạy khi push code)
        // ==========================================
        stage('App CI and Staging Deployment') {
            when {
                not { buildingTag() }
            }
            stages {
                // ── 2. Security & Analysis (Parallel) ────────────────────────────
                // stage('Step 2: Security & Analysis') {
                //     parallel {

                //         stage('SonarQube Scan') {
                //             steps {
                //                 script {
                //                     def scannerHome = tool SONAR_SCANNER
                //                     withSonarQubeEnv(SONAR_SERVER) {
                //                         sh """
                //                             ${scannerHome}/bin/sonar-scanner \
                //                                 -Dsonar.projectKey=${env.JOB_BASE_NAME} \
                //                                 -Dsonar.sources=.
                //                         """
                //                     }
                //                 }
                //             }
                //         }

                //         stage('Hadolint – Dockerfile Lint') {
                //             steps {
                //                 script {
                //                     // [ALLOW FAILURE] exit-code 0 so pipeline continues.
                //                     // TODO: Set --failure-threshold error (or remove || true) once
                //                     //       all Dockerfile warnings have been resolved.
                //                     sh '''
                //                         docker run --rm -i hadolint/hadolint:v2.14.0 hadolint \
                //                             --failure-threshold style \
                //                             - < ./frontend/Dockerfile || true
                //                     '''
                //                 }
                //             }
                //         }

                //         stage('Trivy – Source Scan') {
                //             steps {
                //                 script {
                //                     // [ALLOW FAILURE] --exit-code 0 keeps the build green while
                //                     // the team works through existing HIGH/CRITICAL findings.
                //                     // TODO: Change --exit-code to 1 to enforce hard-fail once
                //                     //       dependency vulnerabilities are remediated.
                //                     sh """
                //                         docker run --rm \
                //                             -v /var/run/docker.sock:/var/run/docker.sock \
                //                             -v \${HOME}/.cache/trivy:/root/.cache/trivy \
                //                             aquasec/trivy:0.69.3 fs \
                //                                 --scanners vuln,secret \
                //                                 --severity HIGH,CRITICAL \
                //                                 --exit-code 0 \
                //                                 --no-progress \
                //                                 .
                //                     """
                //                 }
                //             }
                //         }
                //     }
                // }

                // // ── 3. Quality Gate (SonarQube webhook) ─────────────────────────────
                // stage('Step 3: Quality Gate') {
                //     steps {
                //         // [ALLOW FAILURE] abortPipeline:false keeps the build green while
                //         // the team tunes SonarQube quality profiles.
                //         // TODO: Set abortPipeline:true once the project consistently passes.
                //         timeout(time: 5, unit: 'MINUTES') {
                //             waitForQualityGate abortPipeline: false
                //         }
                //     }
                // }

                // ── 4. Build Docker Image ─────────────────────────────────────────
                stage('Step 4: Build Image') {
                    steps {
                        script {
                            echo "Building image: ${IMAGE_TAG}"
                            sh "docker build -t ${IMAGE_TAG} ./frontend"
                        }
                    }
                }

                // // ── 5. Trivy – Image Scan ─────────────────────────────────────────
                // stage('Step 5: Trivy – Image Scan') {
                //     steps {
                //         script {
                //             // [ALLOW FAILURE] --exit-code 0 lets the pipeline proceed to push
                //             // while the team remediates image-level vulnerabilities.
                //             // TODO: Change --exit-code to 1 to block pushes on HIGH/CRITICAL.
                //             sh """
                //                 docker run --rm \
                //                     -v /var/run/docker.sock:/var/run/docker.sock \
                //                     -v \${HOME}/.cache/trivy:/root/.cache/trivy \
                //                     aquasec/trivy:0.69.3 image \
                //                         --severity HIGH,CRITICAL \
                //                         --exit-code 0 \
                //                         --no-progress \
                //                         ${IMAGE_TAG}
                //             """
                //         }
                //     }
                // }

                // ── 6. Push to Gitea Registry ─────────────────────────────────────
                stage('Step 6: Push to Gitea Registry') {
                    steps {
                        script {
                            withCredentials([string(credentialsId: "${GITEA_CREDS_ID}", variable: 'TOKEN')]) {
                                sh """
                                    echo "\$TOKEN" | docker login ${GITEA_REGISTRY} \
                                        --username admin --password-stdin
                                    docker push ${IMAGE_TAG}
                                    echo "✓ Pushed: ${IMAGE_TAG}"
                                """
                            }
                        }
                    }
                }

                // ── 7. Update Staging Manifests (Trigger Phase 2) ─────────────────
                stage('Step 7: Update Staging Manifests') {
                    steps {
                        // Create an isolated workspace to avoid mixing with the app's source code
                        dir('manifests-workspace') {
                            // Inject Git credentials (Jenkins masks credential values in logs)
                            withCredentials([string(credentialsId: "${GITEA_CREDS_ID}", variable: 'TOKEN')]) {
                                sh '''
                                    set -e
                                    GIT_REPO_URL="http://thanhdc:${TOKEN}@gitea.kltn.internal/kltn/healthcare-manifests.git"

                                    # 1. Clone the manifests repository
                                    # Use token-based auth so non-interactive clone/push works in CI
                                    git clone "${GIT_REPO_URL}" .
                                    
                                    # 2. Create and checkout a temporary branch for this specific build
                                    TEMP_BRANCH="update-staging-frontend-${BUILD_NUMBER}"
                                    git checkout -b ${TEMP_BRANCH}
                                    
                                    # 3. Navigate to the frontend staging overlay directory
                                    cd apps/overlays/staging/frontend

                                    # 4. Update the image tag using 'sed' (Stream Editor)
                                    # This searches for 'newTag: <anything>' and replaces it with 'newTag: <BUILD_NUMBER>'
                                    sed -i "s#newName:.*#newName: $GITEA_REGISTRY/$GITEA_OWNER/$IMAGE_NAME#g" kustomization.yaml
                                    sed -i 's/newTag:.*/newTag: "'"${BUILD_NUMBER}"'"/g' kustomization.yaml

                                    # 5. Commit and push the changes
                                    # Using '-c' to set user.name and user.email inline for this specific commit
                                    git add kustomization.yaml
                                    git -c user.name="thanhdc" -c user.email="chithanh040804@gmail.com" commit -m "ci(staging): update frontend tag to ${BUILD_NUMBER}"
                                    
                                    # Push the temporary branch back to Gitea to trigger Phase 2
                                    git push origin ${TEMP_BRANCH}

                                    # 6. Automatically create a Pull Request via Gitea API
                                    # We send a POST request to the /pulls endpoint
                                    echo "Creating Pull Request for ${TEMP_BRANCH}..."
                                    GIT_TOKEN="${TOKEN}"
                                    PR_PAYLOAD=$(printf '{"base":"main","head":"%s","title":"ci(staging): update frontend to build #%s","body":"This PR was automatically generated by Jenkins Pipeline to update the staging image tag to build #%s."}' "${TEMP_BRANCH}" "${BUILD_NUMBER}" "${BUILD_NUMBER}")

                                    PR_RESPONSE=$(curl --silent --show-error --fail-with-body -X POST "http://gitea.kltn.internal/api/v1/repos/kltn/healthcare-manifests/pulls" \
                                        -H "accept: application/json" \
                                        -H "Authorization: token ${GIT_TOKEN}" \
                                        -H "Content-Type: application/json" \
                                        --data "${PR_PAYLOAD}")

                                    PR_URL=$(echo "${PR_RESPONSE}" | grep -oE '"html_url":"[^"]+"' | head -n 1 | cut -d '"' -f 4 || true)
                                    if [ -n "${PR_URL}" ]; then
                                        echo "✅ Success: Temp branch pushed and Pull Request created: ${PR_URL}"
                                    else
                                        echo "✅ Success: Temp branch pushed and Pull Request created."
                                    fi
                                '''
                            }
                        }
                    }
                }
            }
        }

        // ==========================================
        // PHẦN B: LUỒNG PRODUCTION (Chỉ chạy khi tạo Release)
        // ==========================================
        stage('Production Governance') {
            when {
                buildingTag()
            }
            stages {
                stage('Build Production Image') {
                    steps {
                        script {
                            def releaseTag = env.TAG_NAME ?: env.GIT_TAG
                            if (!releaseTag) {
                                error('Release tag not found. Ensure this build is triggered by a Git tag.')
                            }
                            def prodImageTag = "${GITEA_REGISTRY}/${GITEA_OWNER}/${IMAGE_NAME}:${releaseTag}"

                            echo "🚀 Detected Release Tag: ${releaseTag}. Preparing Production deployment..."
                            sh "docker build -t ${prodImageTag} ./frontend"

                            withCredentials([string(credentialsId: "${GITEA_CREDS_ID}", variable: 'TOKEN')]) {
                                sh """
                                    echo "\$TOKEN" | docker login ${GITEA_REGISTRY} \
                                        --username admin --password-stdin
                                    docker push ${prodImageTag}
                                    echo "✓ Pushed: ${prodImageTag}"
                                """
                            }
                        }
                    }
                }

                stage('Update Prod Manifest & Create PR') {
                    steps {
                        dir('manifests-workspace') {
                            withCredentials([string(credentialsId: "${GITEA_CREDS_ID}", variable: 'TOKEN')]) {
                                sh '''
                                    set -e
                                    if [ -z "${TAG_NAME}" ] && [ -z "${GIT_TAG}" ]; then
                                        echo "Release tag not found in TAG_NAME or GIT_TAG" >&2
                                        exit 1
                                    fi
                                    RELEASE_TAG="${TAG_NAME:-${GIT_TAG}}"

                                    GIT_REPO_URL="http://thanhdc:${TOKEN}@gitea.kltn.internal/kltn/healthcare-manifests.git"
                                    git clone "${GIT_REPO_URL}" .

                                    TEMP_BRANCH="release-prod-${RELEASE_TAG}"
                                    git checkout -b ${TEMP_BRANCH}

                                    cd apps/overlays/production/frontend
                                    sed -i "s#newName:.*#newName: $GITEA_REGISTRY/$GITEA_OWNER/$IMAGE_NAME#g" kustomization.yaml
                                    sed -i 's/newTag:.*/newTag: "'"${RELEASE_TAG}"'"/g' kustomization.yaml

                                    git add kustomization.yaml
                                    git -c user.name="thanhdc" -c user.email="chithanh040804@gmail.com" commit -m "chore(prod): update frontend to ${RELEASE_TAG}"
                                    git push origin ${TEMP_BRANCH}

                                    echo "Creating Production Pull Request for ${TEMP_BRANCH}..."
                                    PR_PAYLOAD=$(printf '{"base":"main","head":"%s","title":"🚀 Deploy to Production: Frontend %s","body":"This PR was generated automatically by Gitea Release %s. Please review carefully before merging."}' "${TEMP_BRANCH}" "${RELEASE_TAG}" "${RELEASE_TAG}")

                                    PR_RESPONSE=$(curl --silent --show-error --fail-with-body -X POST "http://gitea.kltn.internal/api/v1/repos/kltn/healthcare-manifests/pulls" \
                                        -H "accept: application/json" \
                                        -H "Authorization: token ${TOKEN}" \
                                        -H "Content-Type: application/json" \
                                        --data "${PR_PAYLOAD}")

                                    PR_URL=$(echo "${PR_RESPONSE}" | grep -oE '"html_url":"[^"]+"' | head -n 1 | cut -d '"' -f 4 || true)
                                    if [ -n "${PR_URL}" ]; then
                                        echo "✅ Success: Production PR created: ${PR_URL}"
                                    else
                                        echo "✅ Success: Production PR created."
                                    fi
                                '''
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Post-build Cleanup ────────────────────────────────────────────────────────
    post {
        always {
            script {
                echo "=== Post-build Cleanup ==="

                sh "docker logout ${GITEA_REGISTRY} || true"

                // Remove only the image built in this run to avoid wiping cached layers
                // needed by other pipelines on the same runner.
                sh "docker rmi -f ${IMAGE_TAG} || true"

                // Prune dangling images & build cache (safe; does not remove named images)
                sh "docker image prune -f || true"
                sh "docker builder prune -f || true"

                cleanWs()
            }
        }

        success {
            echo "✅ Pipeline PASSED — image pushed: ${IMAGE_TAG}"
        }

        failure {
            echo "❌ Pipeline FAILED — review stage logs above for details."
        }
    }
}
pipeline {
    agent any

    environment {
        // Registry Configuration
        GITEA_REGISTRY  = "gitea.healthcare.com"
        GITEA_OWNER     = "kltn"
        IMAGE_NAME      = "healthcare-frontend"
        GITEA_CREDS_ID  = "gitea-token-admin"

        // SonarQube Configuration
        SONAR_SERVER    = "sonar-server"
        SONAR_SCANNER   = "sonar-scanner"

        // Git Configuration
        GIT_USER_NAME   = "thanhdc"
        GIT_USER_EMAIL  = "chithanh040804@gmail.com"
        
        // Derived Variables
        IMAGE_TAG       = "${GITEA_REGISTRY}/${GITEA_OWNER}/${IMAGE_NAME}:${BUILD_NUMBER}"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    parameters {
        string(
            name: 'RELEASE_TAG',
            defaultValue: '',
            description: 'Release tag to deploy to production (leave empty for staging)'
        )
    }

    stages {

        stage('System Information') {
            steps {
                sh '''
                    echo "=== CPU ===" && lscpu | grep -E "Model|Socket|Core|Thread" || true
                    echo "=== RAM ===" && free -mh
                    echo "=== Disk ===" && df -h
                    echo "=== Docker ===" && docker version --format "Client: {{.Client.Version}}  Server: {{.Server.Version}}"
                '''
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
                echo "Branch: ${env.BRANCH_NAME ?: 'N/A'} | Commit: ${env.GIT_COMMIT?.take(8) ?: 'N/A'}"
            }
        }

        stage('Security & Quality Analysis') {
            parallel {
                stage('SonarQube Scan') {
                    steps {
                        script {
                            def scannerHome = tool SONAR_SCANNER
                            withSonarQubeEnv(SONAR_SERVER) {
                                sh """
                                    ${scannerHome}/bin/sonar-scanner \
                                        -Dsonar.projectKey=${env.JOB_BASE_NAME} \
                                        -Dsonar.sources=.
                                """
                            }
                        }
                    }
                }

                stage('Dockerfile Lint (Hadolint)') {
                    steps {
                        script {
                            // Allow failure - remove '|| true' once all warnings are resolved
                            sh '''
                                docker run --rm -i hadolint/hadolint:v2.14.0 hadolint \
                                    --failure-threshold style \
                                    - < ./frontend/Dockerfile || true
                            '''
                        }
                    }
                }

                stage('Vulnerability Scan (Trivy)') {
                    steps {
                        script {
                            // Allow failure - change --exit-code to 1 once vulnerabilities are remediated
                            sh """
                                docker run --rm \
                                    -v /var/run/docker.sock:/var/run/docker.sock \
                                    -v \${HOME}/.cache/trivy:/root/.cache/trivy \
                                    aquasec/trivy:0.69.3 fs \
                                        --scanners vuln,secret \
                                        --severity HIGH,CRITICAL \
                                        --exit-code 0 \
                                        --no-progress \
                                        .
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                // Allow failure - set abortPipeline:true once project consistently passes
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        // CI & Staging Deployment (runs when RELEASE_TAG is empty)
        stage('Staging Deployment') {
            when {
                allOf {
                    branch 'main'
                    expression { return !params.RELEASE_TAG?.trim() }
                }
            }
            stages {
                stage('Build Staging Image') {
                    steps {
                        script {
                            echo "Building staging image: ${IMAGE_TAG}"
                            sh "docker build -t ${IMAGE_TAG} ./frontend"
                        }
                    }
                }

                stage('Push to Registry') {
                    steps {
                        script {
                            dockerLogin()
                            sh """
                                docker push ${IMAGE_TAG}
                                echo "Pushed: ${IMAGE_TAG}"
                            """
                        }
                    }
                }

                stage('Update Staging Manifests') {
                    steps {
                        script {
                            updateManifests(
                                environment: 'staging',
                                imageTag: BUILD_NUMBER,
                                branch: 'main',
                                commitMessage: "ci(staging): update frontend tag to ${BUILD_NUMBER}"
                            )
                        }
                    }
                }
            }
        }

        // Production Release (runs when RELEASE_TAG is provided)
        stage('Production Release') {
            when {
                expression { return params.RELEASE_TAG?.trim() }
            }
            stages {
                stage('Create Git Tag') {
                    steps {
                        script {
                            echo "Starting production release for: ${params.RELEASE_TAG}"
                            withCredentials([string(credentialsId: "${GITEA_CREDS_ID}", variable: 'TOKEN')]) {
                                sh """
                                    git config user.name "${GIT_USER_NAME}"
                                    git config user.email "${GIT_USER_EMAIL}"
                                    git tag ${params.RELEASE_TAG}
                                    git push http://${GIT_USER_NAME}:\${TOKEN}@gitea.healthcare.com/KLTN/healthcare.git ${params.RELEASE_TAG}
                                """
                            }
                        }
                    }
                }

                stage('Build Production Image') {
                    steps {
                        script {
                            def prodImageTag = "${GITEA_REGISTRY}/${GITEA_OWNER}/${IMAGE_NAME}:${params.RELEASE_TAG}"
                            echo "Building production image: ${prodImageTag}"
                            
                            sh "docker build -t ${prodImageTag} ./frontend"
                            
                            dockerLogin()
                            sh """
                                docker push ${prodImageTag}
                                echo "Pushed: ${prodImageTag}"
                            """
                        }
                    }
                }

                stage('Create Gitea Release') {
                    steps {
                        script {
                            echo "Creating official release on Gitea for tag: ${params.RELEASE_TAG}"
                            withCredentials([string(credentialsId: "${GITEA_CREDS_ID}", variable: 'TOKEN')]) {
                                sh '''
                                    set -e
                                    RELEASE_PAYLOAD=$(printf '{"tag_name":"%s","name":"Release %s","body":"Production release %s automatically built and pushed by Jenkins."}' \
                                        "${RELEASE_TAG}" "${RELEASE_TAG}" "${RELEASE_TAG}")

                                    curl --silent --show-error --fail-with-body \
                                        -X POST "https://gitea.healthcare.com/api/v1/repos/KLTN/healthcare/releases" \
                                        -H "accept: application/json" \
                                        -H "Authorization: token ${TOKEN}" \
                                        -H "Content-Type: application/json" \
                                        --data "${RELEASE_PAYLOAD}"

                                    echo "Gitea release created successfully"
                                '''
                            }
                        }
                    }
                }

                stage('Create Production PR') {
                    steps {
                        script {
                            createProductionPR(
                                releaseTag: params.RELEASE_TAG,
                                imageTag: params.RELEASE_TAG
                            )
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                echo "Post-build cleanup"
                
                sh "docker logout ${GITEA_REGISTRY} || true"
                
                def tagToRemove = params.RELEASE_TAG ?: BUILD_NUMBER
                sh "docker rmi -f ${GITEA_REGISTRY}/${GITEA_OWNER}/${IMAGE_NAME}:${tagToRemove} || true"
                
                sh "docker image prune -f || true"
                sh "docker builder prune -f || true"
                
                cleanWs()
            }
        }

        success {
            echo "Pipeline completed successfully"
        }

        failure {
            echo "Pipeline failed - review stage logs for details"
        }
    }
}

// Helper Functions
def dockerLogin() {
    withCredentials([string(credentialsId: "${GITEA_CREDS_ID}", variable: 'TOKEN')]) {
        sh """
            echo "\$TOKEN" | docker login ${GITEA_REGISTRY} \
                --username admin --password-stdin
        """
    }
}

def updateManifests(Map config) {
    dir('manifests-workspace') {
        withCredentials([string(credentialsId: "${GITEA_CREDS_ID}", variable: 'TOKEN')]) {
            sh """
                set -e
                GIT_REPO_URL="http://${GIT_USER_NAME}:\${TOKEN}@gitea.healthcare.com/KLTN/healthcare-manifests.git"
                git clone "\${GIT_REPO_URL}" .
                git checkout ${config.branch}
                
                cd apps/overlays/${config.environment}/frontend
                sed -i "s#newName:.*#newName: ${GITEA_REGISTRY}/${GITEA_OWNER}/${IMAGE_NAME}#g" kustomization.yaml
                sed -i 's/newTag:.*/newTag: "${config.imageTag}"/g' kustomization.yaml

                git add kustomization.yaml
                git -c user.name="${GIT_USER_NAME}" -c user.email="${GIT_USER_EMAIL}" commit -m "${config.commitMessage}"
                git push origin ${config.branch}
                
                echo "Manifests updated successfully"
            """
        }
    }
}

def createProductionPR(Map config) {
    dir('manifests-workspace') {
        withCredentials([string(credentialsId: "${GITEA_CREDS_ID}", variable: 'TOKEN')]) {
            sh """
                set -e
                
                if [ -z "${config.releaseTag}" ]; then
                    echo "Error: Release tag not provided" >&2
                    exit 1
                fi

                GIT_REPO_URL="http://${GIT_USER_NAME}:\${TOKEN}@gitea.healthcare.com/KLTN/healthcare-manifests.git"
                git clone "\${GIT_REPO_URL}" .

                TEMP_BRANCH="release-prod-${config.releaseTag}"
                git checkout -b \${TEMP_BRANCH}

                cd apps/overlays/production/frontend
                sed -i "s#newName:.*#newName: ${GITEA_REGISTRY}/${GITEA_OWNER}/${IMAGE_NAME}#g" kustomization.yaml
                sed -i 's/newTag:.*/newTag: "${config.imageTag}"/g' kustomization.yaml

                git add kustomization.yaml
                git -c user.name="${GIT_USER_NAME}" -c user.email="${GIT_USER_EMAIL}" commit -m "chore(prod): update frontend to ${config.releaseTag}"
                git push origin \${TEMP_BRANCH}

                echo "Creating production pull request for \${TEMP_BRANCH}"
                
                PR_PAYLOAD=\$(printf '{"base":"main","head":"%s","title":"Deploy to Production: Frontend %s","body":"This PR was generated automatically by Jenkins for Release %s. Please review carefully before merging."}' \
                    "\${TEMP_BRANCH}" "${config.releaseTag}" "${config.releaseTag}")

                PR_RESPONSE=\$(curl --silent --show-error --fail-with-body \
                    -X POST "https://gitea.healthcare.com/api/v1/repos/KLTN/healthcare-manifests/pulls" \
                    -H "accept: application/json" \
                    -H "Authorization: token \${TOKEN}" \
                    -H "Content-Type: application/json" \
                    --data "\${PR_PAYLOAD}")

                PR_URL=\$(echo "\${PR_RESPONSE}" | grep -oE '"html_url":"[^"]+"' | head -n 1 | cut -d '"' -f 4 || true)
                
                if [ -n "\${PR_URL}" ]; then
                    echo "Production PR created: \${PR_URL}"
                else
                    echo "Production PR created successfully"
                fi
            """
        }
    }
}
